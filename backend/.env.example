# Environment variables for DhatuScan backend
# Copy this file to .env and fill in your values

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/dhatuscan?schema=public"

# Test database (used by Jest integration tests)
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/dhatuscan_test?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────────────
# 256-bit random secret for signing JWTs
JWT_SECRET="change-me-to-a-256-bit-random-secret"
JWT_EXPIRES_IN="7d"

# ── Firebase ─────────────────────────────────────────────────────────────────
# Path to your Firebase service-account JSON file downloaded from Firebase console
GOOGLE_APPLICATION_CREDENTIALS="./firebase-service-account.json"

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
